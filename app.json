{
  "expo": {
    "name": "ScrollAway",
    "slug": "reelroam",
    "scheme": "scrollaway",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D9488"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.simen.scrollaway",
      "buildNumber": "1",
      "teamId": "T3FHS868J8",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "scrollaway"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "ScrollAway uses your location to show nearby places on your trip map.",
        "NSCameraUsageDescription": "ScrollAway uses your camera to let you add photos to your trips.",
        "NSPhotoLibraryUsageDescription": "ScrollAway accesses your photos to let you add images to your trips."
      }
    },
    "android": {
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyADEu3-UhuvGiZnmH_6yuwFcmFmmUZsAxM"
        }
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.zimbot420.reelroam",
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "*.tiktok.com"
            },
            {
              "scheme": "https",
              "host": "*.instagram.com"
            },
            {
              "scheme": "https",
              "host": "*.youtube.com"
            },
            {
              "scheme": "https",
              "host": "youtu.be"
            },
            {
              "scheme": "https",
              "host": "vm.tiktok.com"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withPodsSwiftConcurrencyFix",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          },
          "iosAppGroupIdentifier": "group.com.simen.scrollaway",
          "androidIntentFilters": [
            "text/*"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "xcconfig": {
              "SWIFT_STRICT_CONCURRENCY": "minimal"
            }
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2716a19d-fb0f-4b7b-a300-69c99b9fbf61"
      }
    },
    "owner": "zimbot420"
  }
}
